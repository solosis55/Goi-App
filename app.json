{
  "expo": {
    "name": "Goi",
    "slug": "goi",
    "scheme": "goi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Goi usa Face ID para proteger el acceso a tu cuenta en este dispositivo.",
        "NSCameraUsageDescription": "Goi usa la cámara para publicar GoI Daily."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Goi necesita acceso a tus fotos para publicar GoI Daily.",
          "cameraPermission": "Goi necesita la cámara para publicar GoI Daily."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Goi necesita la cámara para publicar GoI Daily.",
          "recordAudioAndroid": false
        }
      ]
    ]
  }
}
