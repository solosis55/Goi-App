{
  "name": "goi",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-qr.ps1",
    "start:qr": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-qr.ps1",
    "start:tunnel": "expo start --tunnel",
    "start:usb": "expo start --localhost",
    "start:phone": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-phone-usb.ps1",
    "start:phone:clear": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-phone-usb.ps1 -c",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:4000 tcp:4000",
    "start:localhost": "expo start --localhost",
    "start:clear": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-qr.ps1 -c",
    "start:localhost:clear": "expo start --localhost -c",
    "android": "expo start --android",
    "android:localhost": "expo start --android --localhost",
    "android:clear": "expo start --android -c",
    "ios": "expo start --ios",
    "ios:clear": "expo start --ios -c",
    "web": "expo start --web"
  },
  "dependencies": {
