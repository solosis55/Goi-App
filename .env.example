# Copia este archivo a `.env` en la raíz de Goi App y ajusta la URL.
# Reinicia Metro (`npx expo start`) tras cambiar variables EXPO_PUBLIC_*.
#
# La URL debe terminar en /api (misma convención que VITE_API_URL en Goi Web).
#
# Por defecto (sin .env):
#   - Android emulador → http://10.0.2.2:4000/api
#   - iOS simulador / web → http://127.0.0.1:4000/api
#
# Dispositivo físico (misma red Wi‑Fi que el PC):
# EXPO_PUBLIC_API_URL=http://192.168.1.10:4000/api
#
# Móvil por USB + adb reverse (npm run adb:reverse):
# EXPO_PUBLIC_API_URL=http://127.0.0.1:4000/api

EXPO_PUBLIC_API_URL=
